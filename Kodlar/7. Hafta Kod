# -------------------------------------------------
# 3) Dynamic Array Resize (2 kat büyütme)
# -------------------------------------------------

"""
template <class T>
void GenericClass<T>::resize()
{
    T* temp = new T[capacity * 2];

    for (int i = 0; i < capacity; i++)
    {
        temp[i] = dataArray[i];
    }

    delete[] dataArray;
    dataArray = temp;

    capacity *= 2;
}
"""


