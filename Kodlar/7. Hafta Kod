# -------------------------------------------------
# 7) Python ile Stack Mantığı
# -------------------------------------------------

class StackYapi:

    def __init__(self):
        self.data = []

    def push(self, value):
        self.data.append(value)

    def pop(self):
        if self.data:
            return self.data.pop()
        return None

    def show(self):
        print(self.data)


stack = StackYapi()
stack.push(10)
stack.push(20)
print("Stack pop:", stack.pop())


# -------------------------------------------------
# 8) Python ile Queue Mantığı
# -------------------------------------------------

class QueueYapi:

    def __init__(self):
        self.data = []

    def enqueue(self, value):
        self.data.append(value)

    def dequeue(self):
        if self.data:
            return self.data.pop(0)
        return None

    def show(self):
        print(self.data)


queue = QueueYapi()
queue.enqueue(10)
queue.enqueue(20)
print("Queue dequeue:", queue.dequeue())


# -------------------------------------------------
# 9) Dizide maksimum değer bulma
# Time Complexity : O(n)
# Space Complexity: O(1)
# -------------------------------------------------

def maksimum_bul(dizi):

    en_buyuk = dizi[0]

    for i in range(1, len(dizi)):
        if dizi[i] > en_buyuk:
            en_buyuk = dizi[i]

    return en_buyuk


ornek = [5, 2, 18, 7, 1]
print("Maksimum:", maksimum_bul(ornek))


# -------------------------------------------------
# 10) Brute Force Maximum Subarray
# Time Complexity : O(n^3)
# -------------------------------------------------

def max_alt_dizi(dizi):

    en_iyi = dizi[0]
    n = len(dizi)

    for i in range(n):
        for j in range(i, n):

            toplam = 0

            for k in range(i, j + 1):
                toplam += dizi[k]

            if toplam > en_iyi:
                en_iyi = toplam

    return en_iyi


sayilar = [4, -1, 2, 1, -5, 4]
print("Max Subarray:", max_alt_dizi(sayilar))


