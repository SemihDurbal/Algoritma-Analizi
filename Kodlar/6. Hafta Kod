# -------------------------------------------------
# 6) Python ile aynı mantığın örneği
# -------------------------------------------------

class DynamicIntArray:

    def __init__(self):
        self.data = [0, 0]
        self.count = 0

    def add(self, value):

        if self.count == len(self.data):
            yeni = [0] * (len(self.data) * 2)

            for i in range(len(self.data)):
                yeni[i] = self.data[i]

            self.data = yeni

        self.data[self.count] = value
        self.count += 1

    def show(self):
        for i in range(self.count):
            print(self.data[i])


# Test
liste = DynamicIntArray()

liste.add(10)
liste.add(20)
liste.add(30)
liste.add(40)

liste.show()


